{
  "port": 8080,
  "tls_enabled": true,
  "validate_input": true,
  "api_token": "${API_TOKEN}",
  "tls_cert_path": "service/cert.pem",
  "tls_key_path": "service/key.pem",
  "circuit_breaker_enabled": true,
  "circuit_breaker_threshold": 3,
  "circuit_breaker_timeout": 10,
  "session_cache_enabled": false
}
