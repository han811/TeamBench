# Bulky per-run artifacts — regenerate via scripts/03_run_all.sh
# We keep the aggregate summary / report files and evidence snapshots, not
# individual turn logs / workspace snapshots which can be large and are
# reproducible from the same (model, condition, task, seed).

# Exclude every timestamped run-directory (shape: YYYYMMDDTHHMMSS_<hex>)
# at any depth under runs/.
runs/**/20[0-9][0-9][0-9][0-9][0-9][0-9]_*/

# Exclude Python cache
__pycache__/
*.pyc

# Exclude stdout/stderr logs (regenerable; can be large)
logs/*.log

# analysis/ outputs are regenerated by 05_analyze.py
analysis/consolidated.json
analysis/statistics.json
analysis/role_compliance.jsonl

# harness.ablation resume checkpoints — regenerable, bloat the repo
runs/*/*.checkpoint.jsonl
